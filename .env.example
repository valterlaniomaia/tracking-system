# ── Shopify (client_credentials auth) ──
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_CLIENT_ID=your_client_id
SHOPIFY_CLIENT_SECRET=shpss_your_client_secret

# ── Klaviyo ──
KLAVIYO_PRIVATE_KEY=pk_your_private_key

# ── ParcelPanel Webhook ──
PARCELPANEL_WEBHOOK_SECRET=

# ── Server ──
PORT=3456
LOG_LEVEL=info

# ── Polling ──
POLLING_INTERVAL_MS=1800000
POLLING_ORDERS_DAYS=30

# ── No Update Thresholds (hours) ──
NO_UPDATE_LEVEL1_HOURS=24
NO_UPDATE_LEVEL2_HOURS=72
NO_UPDATE_LEVEL3_HOURS=120
NO_UPDATE_EXCEPTION_HOURS=168

# ── Retry ──
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000

# ── Store ──
STORE_TYPE=json
STORE_JSON_PATH=./data/order-states.json

# ── Tracking ──
STOP_TRACKING_AFTER_DAYS=45
